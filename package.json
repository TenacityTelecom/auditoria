{
  "name": "auditoria",
  "version": "1.0.0",
  "description": "Microservico de auditoria",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:prod": "npm run build && pm2 start ecosystem.config.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "body-parser": "^1.20.3",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.18",
    "express": "^4.21.2",
    "mysql2": "^3.12.0",
    "sequelize": "^6.37.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "collectCoverageFrom": [
      "src/Controllers/**/*.ts",
      "src/Services/**/*.ts",
      "src/Repositories/**/*.ts",
      "src/Models/**/*.ts",
      "src/errors/**/*.ts",
      "src/Middlewares/**/*.ts",
      "!src/app.ts",
      "!src/database/**/*.ts"
    ]
  }
}
